#!/usr/bin/env Rscript
# ==========================================
# Differential Cell Type Abundance Analysis: TB vs LY
# Purpose: Calculate cell type proportions and test for 
#          significant differences between groups
# ==========================================

# Load required libraries
library(ggplot2)
library(ggpubr)
library(rstatix)
library(dplyr)

# ==========================================
# 1. Calculate cell type proportions per sample
# ==========================================
cell_percent <- seu_End@meta.data %>%
  dplyr::select(
    sample = orig.ident,
    group = group,
    celltype = celltype
  ) %>%
  as.data.frame() %>%
  na.omit() %>%
  dplyr::count(sample, group, celltype) %>%
  group_by(sample) %>%
  mutate(percentage = n / sum(n) * 100) %>%
  ungroup()

# ==========================================
# 2. Summarize: Mean ± Standard Error by group & celltype
# ==========================================
summary_data <- cell_percent %>%
  group_by(group, celltype) %>%
  summarise(
    Mean = mean(percentage),
    SE = sd(percentage) / sqrt(n()),
    .groups = "drop"
  )

# ==========================================
# 3. Statistical testing: Wilcoxon rank-sum test
# ==========================================
stat_test <- cell_percent %>%
  group_by(celltype) %>%
  wilcox_test(percentage ~ group)

# ==========================================
# 4. Prepare annotation data for plot
# ==========================================
stat_test <- stat_test %>%
  mutate(
    group1 = "TB",
    group2 = "LY",
    y.position = max(summary_data$Mean + summary_data$SE) * 1.15,
    xmin = as.numeric(factor(celltype)) - 0.2,
    xmax = as.numeric(factor(celltype)) + 0.2,
    p.signif = case_when(
      p < 0.001 ~ "***",
      p < 0.01  ~ "**",
      p < 0.05  ~ "*",
      TRUE      ~ "ns"
    )
  )

# ==========================================
# 5. Generate bar plot with error bars & significance
# ==========================================
p <- ggplot(summary_data, aes(x = celltype, y = Mean, fill = group)) +
  
  # Bar chart (dodged for side-by-side comparison)
  geom_col(
    position = position_dodge(0.8), 
    width = 0.7, 
    color = "black"
  ) +
  
  # Error bars (Mean ± SE)
  geom_errorbar(
    aes(ymin = Mean - SE, ymax = Mean + SE),
    position = position_dodge(0.8),
    width = 0.2,
    color = "black"
  ) +
  
  # Significance brackets (horizontal lines)
  geom_segment(
    data = stat_test,
    aes(x = xmin, xend = xmax, 
        y = y.position, yend = y.position),
    inherit.aes = FALSE,
    size = 0.8
  ) +
  
  # Significance stars (positioned above brackets)
  geom_text(
    data = stat_test,
    aes(x = (xmin + xmax)/2, y = y.position * 1.05,
        label = p.signif),
    inherit.aes = FALSE,
    size = 6,
    vjust = 0
  ) +
  
  # Color scheme
  scale_fill_manual(values = c("TB" = "#1f77b4", "LY" = "#ff7f0e")) +
  
  # Labels & title
  labs(
    x = "Cell Type",
    y = "Cell Proportion (%)",
    fill = "Group"
  ) +
  
  # Theme & formatting
  theme_classic(base_size = 14) +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    legend.position = "top"
  ) +
  
  # Y-axis expansion for significance annotations
  scale_y_continuous(expand = expansion(mult = c(0, 0.2)))

# Display plot
print(p)
