#!/usr/bin/env Rscript
# ==============================================================================
# Script: 07a.enrichment_comparison.R
# Description: Multi-group comparative enrichment analysis bar plot
# Input: Fib.csv
# Output: Console plot + results/figures/enrichment_comparison.pdf
# ==============================================================================

# Load dependencies
library(dplyr)
library(ggplot2)

# --- 1. Load and Process Data ---
pathway <- read.csv("Fib.csv", header = TRUE)

## Calculate Generation ratio, Background ratio, and Enrichment Fold Change
pathway$Generatio <- pathway$intersection_size / pathway$query_size
pathway$Backgroudratio <- pathway$term_size / pathway$effective_domain_size
pathway$EnrichFoldchange <- pathway$Generatio / pathway$Backgroudratio
kegg <- pathway

# 🔹 Preserve group order as in CSV file
kegg$group <- factor(kegg$group, levels = unique(kegg$group))

# 🔹 Sort by significance within each group (-log10 p-value descending)
kegg <- kegg %>%
  group_by(group) %>%
  arrange(desc(-log10(adjusted_p_value)), .by_group = TRUE) %>%  
  ungroup()

#  Create combined factor for y-axis to maintain internal group ordering
kegg$term_name_grouped <- paste0(kegg$group, "__", kegg$term_name)
kegg$term_name_grouped <- factor(kegg$term_name_grouped, levels = kegg$term_name_grouped)

# --- 2. Define Plot Theme ---
mytheme <- theme(
  axis.title = element_text(face = "bold", size = 10, colour = 'gray25'),
  axis.text = element_text(face = "bold", size = 10, colour = 'gray25'),
  axis.line = element_line(size = 0.5, colour = 'black'),
  axis.ticks.y = element_blank(),
  panel.background = element_rect(fill = "white"),
  panel.grid.major.y = element_blank(),
  panel.grid.minor.y = element_blank(),
  panel.grid.minor.x = element_blank()
)

# --- 3. Generate Comparative Bar Plot ---
plot <- ggplot(kegg, aes(x = -log10(adjusted_p_value),
                         y = term_name_grouped,
                         fill = group)) +
  geom_bar(stat = "identity", width = 0.9) +
  geom_text(aes(x = 0.1, label = term_name),
            hjust = "left", color = "#000000") +
  geom_point(aes(x = 3.5, size = intersection_size, fill = group),
             shape = 21) +
  geom_text(aes(x = 3.5, label = intersection_size)) +
  scale_x_continuous(expand = expansion(mult = c(0, 0.2))) +
  scale_fill_manual(values = c("#74c476", "#41b6c4", "#f46d43", "#9e9ac8",
                               "#e78ac3", "#a6d854", "#ffd92f", "#e5c494",
                               "#b3b3b3", "#bc80bd", "#ffed6f", "#8da0cb",
                               "#66c2a5", "#fc8d62")) +
  scale_size(range = c(5, 8.5),
             guide = guide_legend(override.aes = list(fill = "#000000"))) +
  labs(x = "-log10(adjusted_p_value)", y = "term_name") +
  ggtitle("GO Enrichment") +
  mytheme +
  theme_bw() +
  theme(
    legend.background = element_rect(color = "#969696"),
    panel.border = element_rect(linewidth = 1),
    plot.margin = margin(t = 1, r = 1, b = 1, l = 1, unit = "cm"),
    axis.text = element_text(color = "#000000", size = 14),
    axis.text.y = element_text(size = 14, lineheight = 1.3),
    axis.text.y.left = element_blank(),
    axis.ticks.length.y.left = unit(10, "pt"),
    axis.ticks.y.left = element_line(color = NA),
    axis.title = element_text(color = "#000000", size = 15),
    plot.title = element_text(color = "#000000", size = 20, hjust = 0.5)
  )

# Display plot
print(plot)

# --- 4. Export Figure (GitHub Standard) ---
dir.create("results/figures", recursive = TRUE, showWarnings = FALSE)
ggsave("results/figures/enrichment_comparison.pdf", plot = plot,
       width = 12, height = 10, dpi = 300, bg = "white")
