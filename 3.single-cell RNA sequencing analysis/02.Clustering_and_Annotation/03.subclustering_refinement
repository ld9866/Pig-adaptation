#!/usr/bin/env Rscript
# ==============================================================================
# Script: subclustering_refinement.R
# Description: Subclustering and cell type annotation refinement for major lineages
# ==============================================================================

# ==========================================
# 1. Epithelial Cell Subclustering & Annotation
# ==========================================
## Subclustering of [Cell Type] population
seu_Epi <- subset(seu_obj_anno, cells = rownames(seu_obj_anno@meta.data[seu_obj_anno@meta.data$celltype == "Epi", ]))
table(seu_Epi@meta.data$celltype)
DimPlot(object = seu_Epi, group.by = 'celltype', reduction = "umap", label = TRUE)

seu_Epi <- RunUMAP(seu_Epi, reduction = "harmony", dims = 1:20)
seu_Epi <- FindNeighbors(seu_Epi, reduction = "harmony", dims = 1:20) %>%
  FindClusters(resolution = 0.6)
DimPlot(seu_Epi, reduction = "umap", group.by = "seurat_clusters", label = T, raster = FALSE)

new.celltype.ids <- c("AT2", "AT1", "AT1", "Ciliated", "EFF1B2+Club", "Club", "Ciliated", "Club", "Ciliated", "AT1", "AT2")
names(new.celltype.ids) <- levels(seu_Epi)
seu_Epi <- RenameIdents(seu_Epi, new.celltype.ids)
seu_Epi$celltype <- as.character(Idents(seu_Epi))
DimPlot(seu_Epi, reduction = "umap", label = TRUE, pt.size = 0.5) + NoLegend()

marker <- c("AGER", "CAV1", "PDPN", "EMP2",      # AT1
            "SFTPC", "NAPSA", "SFTPD",            # AT2
            "SCGB3A1", "EEF1B2",                  # EEF1B2+Club
            "CLIC6", "SCGB1A1", "TFF3",           # Club
            "CAPS", "TPPP3", "DYNLRB2", "FOXJ1")  # Ciliated


